<!-- TOAST -->
<div class="toast" id="toast">✅ Item added to cart</div>

<script>
// ── PRODUCT DATA ──
const PRODUCTS = [
  // Grocery
  { id:1, name:'Basmati Rice', unit:'5 kg bag', price:380, cat:'grocery', icon:'🌾' },
  { id:2, name:'Toor Dal', unit:'1 kg', price:145, cat:'grocery', icon:'🫘' },
  { id:3, name:'Mustard Oil', unit:'1 litre', price:185, cat:'grocery', icon:'🫙' },
  { id:4, name:'Sugar', unit:'1 kg', price:48, cat:'grocery', icon:'🍚' },
  { id:5, name:'Wheat Flour (Atta)', unit:'5 kg', price:220, cat:'grocery', icon:'🌾' },
  { id:6, name:'Salt', unit:'1 kg', price:20, cat:'grocery', icon:'🧂' },
  { id:7, name:'Chana Dal', unit:'1 kg', price:110, cat:'grocery', icon:'🫘' },
  { id:8, name:'Turmeric Powder', unit:'200 g', price:45, cat:'grocery', icon:'🟡' },
  // Confectionery
  { id:9, name:'Parle-G Biscuits', unit:'800 g pack', price:55, cat:'confectionery', icon:'🍪' },
  { id:10, name:'Dairy Milk Chocolate', unit:'40 g bar', price:30, cat:'confectionery', icon:'🍫' },
  { id:11, name:'Kurkure', unit:'60 g pack', price:20, cat:'confectionery', icon:'🍟' },
  { id:12, name:'Bourbon Biscuits', unit:'100 g', price:25, cat:'confectionery', icon:'🍪' },
  { id:13, name:'Toffee Mix', unit:'50 pieces', price:50, cat:'confectionery', icon:'🍬' },
  { id:14, name:'Choco Pie', unit:'6 pcs box', price:60, cat:'confectionery', icon:'🧁' },
  // Fruits & Veggies
  { id:15, name:'Tomatoes', unit:'1 kg', price:35, cat:'fruits', icon:'🍅' },
  { id:16, name:'Onions', unit:'1 kg', price:40, cat:'fruits', icon:'🧅' },
  { id:17, name:'Potatoes', unit:'1 kg', price:30, cat:'fruits', icon:'🥔' },
  { id:18, name:'Bananas', unit:'1 dozen', price:45, cat:'fruits', icon:'🍌' },
  { id:19, name:'Apples (Shimla)', unit:'1 kg', price:120, cat:'fruits', icon:'🍎' },
  { id:20, name:'Spinach', unit:'1 bunch', price:20, cat:'fruits', icon:'🥬' },
  // Utensils
  { id:21, name:'Steel Tiffin Box', unit:'3 tier', price:320, cat:'utensils', icon:'🥡' },
  { id:22, name:'Non-stick Tawa', unit:'28 cm', price:450, cat:'utensils', icon:'🍳' },
  { id:23, name:'Steel Kadai', unit:'Medium', price:380, cat:'utensils', icon:'🫕' },
  { id:24, name:'Pressure Cooker', unit:'3 litre', price:1200, cat:'utensils', icon:'🫙' },
  // Others
  { id:25, name:'Surf Excel Detergent', unit:'1 kg', price:145, cat:'other', icon:'🧺' },
  { id:26, name:'Colgate Toothpaste', unit:'150 g', price:85, cat:'other', icon:'🪥' },
  { id:27, name:'Lifebuoy Soap', unit:'3 bars', price:68, cat:'other', icon:'🧼' },
  { id:28, name:'Dettol Handwash', unit:'200 ml', price:95, cat:'other', icon:'🫧' },
];

let cart = {}; // { productId: qty }
let currentFilter = 'all';

function setFilter(btn, cat) {
  currentFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts();
}
function filterCategory(cat) {
  currentFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(b => {
    b.classList.toggle('active', b.textContent.trim().toLowerCase().includes(cat) || cat === 'all' && b.textContent.trim() === 'All');
  });
  renderProducts();
}

function renderProducts() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const grid = document.getElementById('productsGrid');
  const noRes = document.getElementById('noResults');
  let items = PRODUCTS.filter(p => {
    const matchCat = currentFilter === 'all' || p.cat === currentFilter;
    const matchSearch = p.name.toLowerCase().includes(search) || p.unit.toLowerCase().includes(search);
    return matchCat && matchSearch;
  });
  if (items.length === 0) {
    grid.innerHTML = '';
    noRes.style.display = 'block';
    return;
  }
  noRes.style.display = 'none';
  grid.innerHTML = items.map(p => {
    const qty = cart[p.id] || 0;
    return `<div class="product-card" id="pcard-${p.id}">
      <div class="product-img">${p.icon}</div>
      <div class="product-body">
        <div class="product-name">${p.name}</div>
        <div class="product-unit">${p.unit}</div>
        <div class="product-footer">
          <div class="product-price">₹${p.price}</div>
          ${qty === 0
            ? `<button class="add-btn" onclick="addToCart(${p.id})">+ Add</button>`
            : `<div class="qty-ctrl">
                <button class="qty-minus" onclick="changeQty(${p.id},-1)">−</button>
                <span class="qty-num">${qty}</span>
                <button class="qty-plus" onclick="changeQty(${p.id},1)">+</button>
               </div>`
          }
        </div>
      </div>
    </div>`;
  }).join('');
}

function addToCart(id) {
  cart[id] = 1;
  renderProducts();
  updateCart();
  showToast('✅ Added to cart!');
}
function changeQty(id, delta) {
  cart[id] = (cart[id] || 0) + delta;
  if (cart[id] <= 0) delete cart[id];
  renderProducts();
  updateCart();
}

function updateCart() {
  const ids = Object.keys(cart);
  const cartEl = document.getElementById('cartItems');
  const totalsEl = document.getElementById('cartTotals');
  const navCount = document.getElementById('navCartCount');
  const totalQty = ids.reduce((s, id) => s + cart[id], 0);
  navCount.textContent = totalQty;
  if (ids.length === 0) {
    cartEl.innerHTML = '<div class="cart-empty">Your cart is empty.<br>Add items from the shop! 🛍</div>';
    totalsEl.style.display = 'none';
    return;
  }
  let subtotal = 0;
  cartEl.innerHTML = ids.map(id => {
    const p = PRODUCTS.find(x => x.id == id);
    const lineTotal = p.price * cart[id];
    subtotal += lineTotal;
    return `<div class="cart-item">
      <span class="cart-item-name">${p.icon} ${p.name}</span>
      <span class="cart-item-qty">×${cart[id]}</span>
      <span class="cart-item-price">₹${lineTotal}</span>
      <button class="cart-rm" onclick="removeCartItem(${id})" title="Remove">✕</button>
    </div>`;
  }).join('');
  document.getElementById('subtotalVal').textContent = '₹' + subtotal;
  document.getElementById('totalVal').textContent = '₹' + subtotal;
  totalsEl.style.display = 'block';
}

function removeCartItem(id) {
  delete cart[id];
  renderProducts();
  updateCart();
}

let orderNum = 1000;
function placeOrder() {
  const name = document.getElementById('custName').value.trim();
  const phone = document.getElementById('custPhone').value.trim();
  if (Object.keys(cart).length === 0) { showToast('🛒 Cart is empty!'); return; }
  if (!name) { showToast('⚠️ Please enter your name'); return; }
  if (!/^[0-9]{10}$/.test(phone)) { showToast('⚠️ Enter a valid 10-digit phone number'); return; }
  orderNum++;
  const oid = 'RGS' + orderNum;
  document.getElementById('modalOrderId').textContent = 'Order #' + oid;
  document.getElementById('modalMsg').innerHTML = `Hi <strong>${name}</strong>! Your order is being packed. Please pay via UPI <strong>ravigeneralstore@upi</strong> and show the screenshot to the store owner when you pick up. Call <strong>+91 98765 43210</strong> for any query.`;
  document.getElementById('successModal').classList.add('open');
  cart = {};
  renderProducts();
  updateCart();
  document.getElementById('custName').value = '';
  document.getElementById('custPhone').value = '';
  document.getElementById('custNote').value = '';
}
function closeModal() { document.getElementById('successModal').classList.remove('open'); }

function applyJob(role) {
  showToast(`📩 Application for "${role}" sent! We'll contact you soon.`);
}

let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2400);
}

// Init
renderProducts();
updateCart();
</script>
