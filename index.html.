<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ravi General Store – Your Neighbourhood Store</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --green: #1a7a4a;
  --green-light: #27ae60;
  --green-pale: #e8f5ed;
  --orange: #e67e22;
  --orange-light: #f39c12;
  --red: #e74c3c;
  --dark: #1a1a2e;
  --gray: #6b7280;
  --bg: #f9fafb;
  --white: #ffffff;
  --shadow: 0 4px 24px rgba(0,0,0,0.10);
  --radius: 16px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--dark); }

/* ── NAV ── */
nav {
  position: sticky; top: 0; z-index: 100;
  background: var(--green);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px; height: 64px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.15);
}
.nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.nav-logo { font-size: 28px; }
.nav-name { font-family: 'Baloo 2', cursive; font-size: 1.4rem; font-weight: 800; color: #fff; letter-spacing: .5px; }
.nav-links { display: flex; gap: 8px; align-items: center; }
.nav-links a {
  color: rgba(255,255,255,0.85); text-decoration: none;
  font-weight: 600; font-size: .9rem; padding: 8px 14px; border-radius: 8px;
  transition: background .2s, color .2s;
}
.nav-links a:hover { background: rgba(255,255,255,0.15); color: #fff; }
.cart-btn {
  background: var(--orange); color: #fff !important; border-radius: 8px !important;
  display: flex; align-items: center; gap: 6px;
}
.cart-count {
  background: #fff; color: var(--orange);
  font-size: .75rem; font-weight: 700;
  border-radius: 100px; padding: 1px 6px; min-width: 20px; text-align: center;
}

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, #1a7a4a 0%, #145c38 60%, #0f4028 100%);
  color: #fff; padding: 64px 32px 56px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 32px; flex-wrap: wrap;
}
.hero-text h1 { font-family: 'Baloo 2', cursive; font-size: 3rem; font-weight: 800; line-height: 1.1; }
.hero-text h1 span { color: #f9ca24; }
.hero-text p { margin: 16px 0 28px; font-size: 1.1rem; opacity: .9; max-width: 480px; }
.hero-badges { display: flex; gap: 10px; flex-wrap: wrap; }
.badge {
  background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25);
  padding: 6px 14px; border-radius: 100px; font-size: .85rem; font-weight: 600;
  display: flex; align-items: center; gap: 6px;
}
.hero-actions { display: flex; gap: 12px; margin-top: 28px; flex-wrap: wrap; }
.btn-primary {
  background: var(--orange); color: #fff; border: none; border-radius: 10px;
  padding: 14px 28px; font-size: 1rem; font-weight: 700; cursor: pointer;
  font-family: 'Nunito', sans-serif; transition: transform .15s, box-shadow .15s;
  text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(230,126,34,.4); }
.btn-secondary {
  background: rgba(255,255,255,0.15); color: #fff; border: 2px solid rgba(255,255,255,0.4);
  border-radius: 10px; padding: 12px 24px; font-size: 1rem; font-weight: 700; cursor: pointer;
  font-family: 'Nunito', sans-serif; transition: background .2s; text-decoration: none;
}
.btn-secondary:hover { background: rgba(255,255,255,0.25); }
.hero-art { font-size: 120px; line-height: 1; filter: drop-shadow(0 8px 24px rgba(0,0,0,.2)); }

/* ── UPI BANNER ── */
.upi-banner {
  background: linear-gradient(90deg, #f9ca24, #f0932b);
  padding: 14px 32px; display: flex; align-items: center; justify-content: center;
  gap: 16px; flex-wrap: wrap;
}
.upi-banner p { font-weight: 700; font-size: .95rem; color: #222; }
.upi-id {
  background: rgba(0,0,0,0.1); border-radius: 8px; padding: 4px 12px;
  font-family: monospace; font-size: .95rem; font-weight: 700; color: #111;
}

/* ── SECTION ── */
section { padding: 56px 32px; }
.section-header { text-align: center; margin-bottom: 36px; }
.section-header h2 { font-family: 'Baloo 2', cursive; font-size: 2rem; font-weight: 800; color: var(--dark); }
.section-header p { color: var(--gray); margin-top: 6px; font-size: 1rem; }
.tag {
  display: inline-block; background: var(--green-pale); color: var(--green);
  border-radius: 100px; padding: 4px 14px; font-size: .8rem; font-weight: 700;
  margin-bottom: 8px; letter-spacing: .5px; text-transform: uppercase;
}

/* ── CATEGORIES ── */
.cats-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px;
}
.cat-card {
  background: var(--white); border-radius: var(--radius); padding: 28px 16px;
  text-align: center; cursor: pointer; transition: transform .2s, box-shadow .2s;
  box-shadow: 0 2px 12px rgba(0,0,0,.06); border: 2px solid transparent;
  text-decoration: none; color: var(--dark); display: block;
}
.cat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); border-color: var(--green-light); }
.cat-icon { font-size: 44px; margin-bottom: 10px; display: block; }
.cat-name { font-weight: 700; font-size: .95rem; }
.cat-count { font-size: .8rem; color: var(--gray); margin-top: 4px; }

/* ── PRODUCTS ── */
#products { background: var(--white); }
.filter-bar {
  display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px;
  align-items: center; justify-content: center;
}
.filter-btn {
  background: var(--bg); border: 2px solid #e5e7eb; border-radius: 100px;
  padding: 8px 18px; font-size: .88rem; font-weight: 600; cursor: pointer;
  font-family: 'Nunito', sans-serif; color: var(--dark); transition: all .2s;
}
.filter-btn.active, .filter-btn:hover {
  background: var(--green); border-color: var(--green); color: #fff;
}
.search-bar {
  flex: 1; max-width: 320px; display: flex; align-items: center;
  background: var(--bg); border: 2px solid #e5e7eb; border-radius: 100px;
  padding: 8px 16px; gap: 8px;
}
.search-bar input {
  border: none; background: transparent; outline: none;
  font-family: 'Nunito', sans-serif; font-size: .9rem; color: var(--dark); flex: 1;
}
.products-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px;
}
.product-card {
  background: var(--white); border-radius: var(--radius); overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,.07); transition: transform .2s, box-shadow .2s;
  border: 2px solid #f0f0f0;
}
.product-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
.product-img { width: 100%; height: 140px; object-fit: cover; display: flex; align-items: center; justify-content: center; font-size: 56px; background: var(--green-pale); }
.product-body { padding: 14px; }
.product-name { font-weight: 700; font-size: .95rem; margin-bottom: 4px; }
.product-unit { font-size: .8rem; color: var(--gray); }
.product-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; }
.product-price { font-family: 'Baloo 2', cursive; font-size: 1.15rem; font-weight: 700; color: var(--green); }
.add-btn {
  background: var(--green); color: #fff; border: none; border-radius: 8px;
  padding: 7px 14px; font-size: .85rem; font-weight: 700; cursor: pointer;
  font-family: 'Nunito', sans-serif; transition: background .2s; display: flex; align-items: center; gap: 4px;
}
.add-btn:hover { background: var(--green-light); }
.add-btn.added { background: var(--orange); }
.qty-ctrl { display: flex; align-items: center; gap: 6px; }
.qty-ctrl button {
  width: 28px; height: 28px; border-radius: 6px; border: none; cursor: pointer;
  font-size: 1rem; font-weight: 700; font-family: 'Nunito', sans-serif;
}
.qty-minus { background: #fee2e2; color: var(--red); }
.qty-plus { background: var(--green-pale); color: var(--green); }
.qty-num { font-weight: 700; min-width: 20px; text-align: center; }
.no-results { text-align: center; padding: 40px; color: var(--gray); font-size: 1rem; display: none; }

/* ── HOW IT WORKS ── */
#how { background: var(--green-pale); }
.steps { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
.step {
  background: var(--white); border-radius: var(--radius); padding: 28px 24px;
  text-align: center; flex: 1; min-width: 200px; max-width: 240px; box-shadow: 0 2px 12px rgba(0,0,0,.06);
}
.step-num {
  width: 44px; height: 44px; background: var(--green); color: #fff;
  border-radius: 100%; display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: 1.1rem; margin: 0 auto 14px;
}
.step h3 { font-weight: 700; margin-bottom: 8px; }
.step p { font-size: .88rem; color: var(--gray); }

/* ── ORDER / CART ── */
#order { background: var(--white); }
.order-layout { display: flex; gap: 32px; flex-wrap: wrap; }
.order-form-wrap { flex: 1; min-width: 300px; }
.cart-wrap { flex: 0 0 340px; min-width: 280px; }
.form-group { margin-bottom: 18px; }
label { display: block; font-weight: 700; font-size: .88rem; margin-bottom: 6px; color: var(--dark); }
input, select, textarea {
  width: 100%; padding: 12px 14px; border: 2px solid #e5e7eb; border-radius: 10px;
  font-family: 'Nunito', sans-serif; font-size: .9rem; outline: none; transition: border-color .2s;
}
input:focus, select:focus, textarea:focus { border-color: var(--green); }
.form-row { display: flex; gap: 14px; }
.form-row .form-group { flex: 1; }
.cart-box {
  background: var(--bg); border-radius: var(--radius); padding: 20px;
  border: 2px solid #e5e7eb; position: sticky; top: 80px;
}
.cart-box h3 { font-family: 'Baloo 2', cursive; font-size: 1.3rem; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.cart-items { max-height: 280px; overflow-y: auto; }
.cart-item {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 0; border-bottom: 1px solid #e5e7eb; font-size: .88rem;
}
.cart-item-name { flex: 1; font-weight: 600; }
.cart-item-qty { color: var(--gray); }
.cart-item-price { font-weight: 700; color: var(--green); }
.cart-rm { background: none; border: none; color: var(--red); cursor: pointer; font-size: 1rem; padding: 2px; }
.cart-empty { text-align: center; color: var(--gray); padding: 24px; font-size: .9rem; }
.cart-totals { margin-top: 14px; padding-top: 14px; border-top: 2px solid #e5e7eb; }
.cart-row { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: .9rem; }
.cart-row.total { font-weight: 800; font-size: 1.05rem; color: var(--green); }
.upi-pay-box {
  margin-top: 14px; background: #fff8e1; border: 2px solid #f9ca24; border-radius: 10px;
  padding: 12px; text-align: center;
}
.upi-pay-box p { font-size: .82rem; color: #666; }
.upi-pay-box .upi-big { font-family: monospace; font-size: 1.05rem; font-weight: 700; color: var(--green); margin: 4px 0; }
.place-order-btn {
  width: 100%; margin-top: 14px; background: var(--green); color: #fff; border: none;
  border-radius: 10px; padding: 14px; font-size: 1rem; font-weight: 700; cursor: pointer;
  font-family: 'Nunito', sans-serif; transition: background .2s;
}
.place-order-btn:hover { background: var(--green-light); }

/* ── MODAL ── */
.modal-overlay {
  display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5);
  z-index: 999; align-items: center; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
  background: #fff; border-radius: 20px; padding: 40px 32px; max-width: 440px; width: 90%;
  text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,.25); animation: popIn .3s ease;
}
@keyframes popIn { from { transform: scale(.85); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.modal-icon { font-size: 64px; margin-bottom: 16px; }
.modal h2 { font-family: 'Baloo 2', cursive; font-size: 1.8rem; font-weight: 800; margin-bottom: 10px; }
.modal p { color: var(--gray); margin-bottom: 20px; line-height: 1.6; }
.order-id { font-family: monospace; background: var(--green-pale); color: var(--green); padding: 6px 16px; border-radius: 8px; font-weight: 700; font-size: 1rem; display: inline-block; margin-bottom: 16px; }

/* ── CAREERS ── */
#careers { background: var(--dark); color: #fff; }
#careers .section-header h2 { color: #fff; }
#careers .section-header p { color: rgba(255,255,255,.6); }
.jobs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; }
.job-card {
  background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--radius); padding: 24px;
}
.job-card h3 { font-weight: 700; margin-bottom: 6px; font-size: 1.05rem; }
.job-card p { font-size: .85rem; color: rgba(255,255,255,.6); margin-bottom: 14px; }
.job-tag { background: var(--green); border-radius: 100px; padding: 4px 12px; font-size: .78rem; font-weight: 700; margin-right: 6px; }
.apply-btn {
  margin-top: 16px; background: var(--orange); color: #fff; border: none;
  border-radius: 8px; padding: 10px 20px; font-size: .88rem; font-weight: 700;
  cursor: pointer; font-family: 'Nunito', sans-serif; transition: background .2s;
}
.apply-btn:hover { background: var(--orange-light); }

/* ── CONTACT ── */
#contact { background: var(--white); }
.contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
.contact-card {
  background: var(--green-pale); border-radius: var(--radius); padding: 24px;
  display: flex; gap: 16px; align-items: flex-start;
}
.contact-icon { font-size: 32px; flex-shrink: 0; }
.contact-card h4 { font-weight: 700; margin-bottom: 6px; }
.contact-card p { font-size: .88rem; color: var(--gray); line-height: 1.6; }
.contact-card a { color: var(--green); font-weight: 600; text-decoration: none; }
.map-frame { width: 100%; height: 260px; border: none; border-radius: var(--radius); margin-top: 28px; filter: saturate(.8); }

/* ── FOOTER ── */
footer {
  background: var(--dark); color: rgba(255,255,255,.6);
  padding: 28px 32px; display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 12px; font-size: .85rem;
}
footer strong { color: #fff; }
.footer-links { display: flex; gap: 16px; }
.footer-links a { color: rgba(255,255,255,.5); text-decoration: none; }
.footer-links a:hover { color: #fff; }

/* ── TOAST ── */
.toast {
  position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
  background: var(--dark); color: #fff; padding: 12px 24px; border-radius: 100px;
  font-weight: 600; font-size: .9rem; z-index: 9999;
  opacity: 0; transition: opacity .3s; pointer-events: none;
  display: flex; align-items: center; gap: 8px;
}
.toast.show { opacity: 1; }

@media(max-width:600px){
  nav { padding: 0 14px; }
  .nav-links a:not(.cart-btn) { display: none; }
  .hero { padding: 40px 16px 36px; }
  .hero-text h1 { font-size: 2rem; }
  .hero-art { font-size: 70px; }
  section { padding: 36px 16px; }
  .upi-banner { padding: 12px 16px; }
  footer { padding: 20px 16px; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-brand" href="#">
    <span class="nav-logo">🛒</span>
    <span class="nav-name">Ravi General Store</span>
  </a>
  <div class="nav-links">
    <a href="#products">Shop</a>
    <a href="#how">How It Works</a>
    <a href="#careers">Careers</a>
    <a href="#contact">Contact</a>
    <a href="#order" class="cart-btn">🛒 Cart <span class="cart-count" id="navCartCount">0</span></a>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-text">
    <h1>Your Neighbourhood<br><span>Ravi General Store</span></h1>
    <p>Groceries, confectionery, fruits & veggies, utensils and more — ordered online, packed fresh, ready for pickup!</p>
    <div class="hero-badges">
      <span class="badge">✅ Online Orders</span>
      <span class="badge">📦 Self Pickup</span>
      <span class="badge">💳 UPI Payment</span>
      <span class="badge">🌿 Fresh Daily</span>
    </div>
    <div class="hero-actions">
      <a href="#products" class="btn-primary">🛍 Shop Now</a>
      <a href="#how" class="btn-secondary">How It Works</a>
    </div>
  </div>
  <div class="hero-art">🏪</div>
</div>

<!-- UPI BANNER -->
<div class="upi-banner">
  <p>💳 We accept UPI payments!</p>
  <span class="upi-id">ravigeneralstore@upi</span>
  <p>Pay before pickup • Google Pay • PhonePe • Paytm</p>
</div>

<!-- CATEGORIES -->
<section id="categories">
  <div class="section-header">
    <span class="tag">Browse by Category</span>
    <h2>What are you looking for?</h2>
    <p>Click a category to filter products below</p>
  </div>
  <div class="cats-grid">
    <a href="#products" class="cat-card" onclick="filterCategory('all')">
      <span class="cat-icon">🛒</span>
      <div class="cat-name">All Items</div>
      <div class="cat-count">View All</div>
    </a>
    <a href="#products" class="cat-card" onclick="filterCategory('grocery')">
      <span class="cat-icon">🌾</span>
      <div class="cat-name">Grocery</div>
      <div class="cat-count">Rice, Dal, Oil & more</div>
    </a>
    <a href="#products" class="cat-card" onclick="filterCategory('confectionery')">
      <span class="cat-icon">🍬</span>
      <div class="cat-name">Confectionery</div>
      <div class="cat-count">Biscuits, Chocolates</div>
    </a>
    <a href="#products" class="cat-card" onclick="filterCategory('fruits')">
      <span class="cat-icon">🍎</span>
      <div class="cat-name">Fruits & Veggies</div>
      <div class="cat-count">Fresh everyday</div>
    </a>
    <a href="#products" class="cat-card" onclick="filterCategory('utensils')">
      <span class="cat-icon">🍳</span>
      <div class="cat-name">Utensils</div>
      <div class="cat-count">Cookware & more</div>
    </a>
    <a href="#products" class="cat-card" onclick="filterCategory('other')">
      <span class="cat-icon">🧴</span>
      <div class="cat-name">Others</div>
      <div class="cat-count">Daily needs</div>
    </a>
  </div>
</section>

<!-- PRODUCTS -->
<section id="products">
  <div class="section-header">
    <span class="tag">Our Products</span>
    <h2>Fresh & Ready to Order</h2>
  </div>
  <div class="filter-bar">
    <div class="search-bar">
      <span>🔍</span>
      <input type="text" id="searchInput" placeholder="Search products…" oninput="renderProducts()">
    </div>
    <button class="filter-btn active" onclick="setFilter(this,'all')">All</button>
    <button class="filter-btn" onclick="setFilter(this,'grocery')">🌾 Grocery</button>
    <button class="filter-btn" onclick="setFilter(this,'confectionery')">🍬 Confectionery</button>
    <button class="filter-btn" onclick="setFilter(this,'fruits')">🍎 Fruits & Veggies</button>
    <button class="filter-btn" onclick="setFilter(this,'utensils')">🍳 Utensils</button>
    <button class="filter-btn" onclick="setFilter(this,'other')">🧴 Others</button>
  </div>
  <div class="products-grid" id="productsGrid"></div>
  <div class="no-results" id="noResults">No products found. Try a different search!</div>
</section>

<!-- HOW IT WORKS -->
<section id="how">
  <div class="section-header">
    <span class="tag">Easy Process</span>
    <h2>How to Order</h2>
    <p>Order online, pay via UPI, and pick up from our store.</p>
  </div>
  <div class="steps">
    <div class="step">
      <div class="step-num">1</div>
      <div style="font-size:36px;margin-bottom:8px;">🛍</div>
      <h3>Browse & Add</h3>
      <p>Browse categories, add items to your cart</p>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div style="font-size:36px;margin-bottom:8px;">📋</div>
      <h3>Place Order</h3>
      <p>Fill your name, phone, and place the order</p>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div style="font-size:36px;margin-bottom:8px;">💳</div>
      <h3>Pay via UPI</h3>
      <p>Pay using <strong>ravigeneralstore@upi</strong> — Google Pay, PhonePe, Paytm</p>
    </div>
    <div class="step">
      <div class="step-num">4</div>
      <div style="font-size:36px;margin-bottom:8px;">📦</div>
      <h3>We Pack It</h3>
      <p>Your order is carefully picked & packed</p>
    </div>
    <div class="step">
      <div class="step-num">5</div>
      <div style="font-size:36px;margin-bottom:8px;">🏃</div>
      <h3>Pickup Ready!</h3>
      <p>Visit the store, show your order ID, take your order!</p>
    </div>
  </div>
</section>

<!-- ORDER SECTION -->
<section id="order">
  <div class="section-header">
    <span class="tag">Place Order</span>
    <h2>Complete Your Order</h2>
    <p>Fill in your details and review your cart</p>
  </div>
  <div class="order-layout">
    <div class="order-form-wrap">
      <div class="form-row">
